{
  "name": "galaxy-game",
  "version": "0.1.0",
  "description": "A 2D top-down space grand strategy game inspired by Stellaris",
  "type": "module",
  "main": "dist/server/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server/index.ts",
    "start": "node dist/server/index.js",
    "db:init": "tsx src/server/database/init.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "game",
    "strategy",
    "space",
    "stellaris"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.15",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  }
}
